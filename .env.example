# Cloudflare Worker secrets/vars.
# Configure with `npx wrangler secret put <NAME>` or dashboard environment vars.
# For mailing-list-delivered menus, set this to the list address (e.g. gbemploy@listmgr.nrao.edu),
# not the human author's address — the list rewrites From: to the list itself.
ALLOWED_SENDER=cafeteria@example.com
SLACK_SIGNING_SECRET=replace-with-slack-signing-secret
SLACK_BOT_TOKEN=xoxb-replace-with-bot-token
SLACK_CHANNEL_ID=C0123456789
ADMIN_TOKEN=replace-with-random-admin-token
